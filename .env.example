# =========================
# Discord
# =========================
DISCORD_BOT_TOKEN=replace-with-discord-bot-token
DISCORD_GUILD_ID=123456789
DISCORD_SOURCE_CHANNEL_ID=123456789
DISCORD_APPLICATION_ID=123456789

# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=@yourpublicchannel
TELEGRAM_THREAD_ID=

# =========================
# AI Provider
# =========================
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=replace-with-ai-api-key
AI_BASE_URL=

# =========================
# Database
# =========================
DATABASE_URL=sqlite+aiosqlite:///data/news.db

# =========================
# Application
# =========================
APP_ENV=production
LOG_LEVEL=INFO
TIMEZONE=UTC
PORT=8000
ENABLE_TRANSLATION=true
ENABLE_AI_CACHE=true
ENABLE_MARKET_IMPACT=true
ENABLE_DUPLICATE_DETECTION=true
