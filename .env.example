# =========================
# News Ingestion (RSS — FinancialJuice)
# =========================
FJ_RSS_URL=https://www.financialjuice.com/feed.ashx?xy=rss
RSS_POLL_INTERVAL=30

# Optional: FinancialJuice Stream API key for real-time WebSocket feed
# FJ_STREAM_API_KEY=fj_your_api_key_here

# =========================
# Telegram
# =========================
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_CHAT_ID=@yourpublicchannel
TELEGRAM_THREAD_ID=

# =========================
# AI Provider
# =========================
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=replace-with-ai-api-key
AI_BASE_URL=

# =========================
# Database
# =========================
DATABASE_URL=sqlite+aiosqlite:///data/news.db

# =========================
# Application
# =========================
APP_ENV=production
LOG_LEVEL=INFO
TIMEZONE=UTC
PORT=8000

# =========================
# Features
# =========================
ENABLE_TRANSLATION=true
ENABLE_AI_CACHE=true
ENABLE_MARKET_IMPACT=true
ENABLE_DUPLICATE_DETECTION=true
